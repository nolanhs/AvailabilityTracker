{
  "scripts": {
    "ci": "npm run format:check && npm run lint:html && npm run lint:css",
    "format:check": "prettier -c \"../**/*.{html,css,js,json,md}\"",
    "lint:html": "htmlhint \"../**/*.html\"",
    "lint:css": "stylelint \"../**/*.css\""
  },
  "devDependencies": {
    "htmlhint": "^1.8.0",
    "prettier": "^3.8.1",
    "stylelint": "^17.0.0"
  }
}
